{
  "name": "mybatis-log-formatter",
  "displayName": "MyBatis Log Formatter",
  "description": "Parse, format, and inline MyBatis SQL log blocks (Preparing/Parameters/Row/Total) in the current file",
  "version": "1.0.1",
  "icon": "media/icon-256.png",
  "publisher": "thevirtualworld",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/virtualworldAlex/vscode-mybatis-log-formatter.git"
  },
  "bugs": "https://github.com/virtualworldAlex/vscode-mybatis-log-formatter/issues",
  "homepage": "https://github.com/virtualworldAlex/vscode-mybatis-log-formatter#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "mybatis",
    "sql",
    "sql-formatter",
    "jdbc",
    "preparing",
    "parameters",
    "java"
  ],
  "qna": "https://github.com/virtualworldAlex/vscode-mybatis-log-formatter/issues",
  "galleryBanner": {
    "color": "#0F4C81",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:mybatisLogFormatter.formatCurrentDocument",
    "onCommand:mybatisLogFormatter.formatSelection",
    "onCommand:mybatisLogFormatter.previewCurrentDocument"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mybatisLogFormatter.formatCurrentDocument",
        "title": "MyBatis Log Formatter: Format Current Document"
      },
      {
        "command": "mybatisLogFormatter.formatSelection",
        "title": "MyBatis Log Formatter: Format Selection"
      },
      {
        "command": "mybatisLogFormatter.previewCurrentDocument",
        "title": "MyBatis Log Formatter: Preview Current Document"
      }
    ],
    "configuration": {
      "title": "MyBatis Log Formatter",
      "properties": {
        "mybatisLogFormatter.autoFormat": {
          "type": "boolean",
          "default": true,
          "description": "Insert formatted SQL directly. When false, show Webview preview first."
        },
        "mybatisLogFormatter.indentSize": {
          "type": "number",
          "enum": [
            2,
            4
          ],
          "default": 4,
          "description": "Indent size for formatted SQL"
        },
        "mybatisLogFormatter.keywordCase": {
          "type": "string",
          "enum": [
            "upper",
            "lower",
            "preserve"
          ],
          "default": "upper",
          "description": "Keyword case in formatted SQL"
        },
        "mybatisLogFormatter.paramMode": {
          "type": "string",
          "enum": [
            "inline",
            "placeholder"
          ],
          "default": "inline",
          "description": "Parameter representation: inline (literal) or placeholder (? with comments)"
        },
        "mybatisLogFormatter.stringQuote": {
          "type": "string",
          "enum": [
            "single",
            "double"
          ],
          "default": "single",
          "description": "Quote character for string literals"
        }
      }
    },
    "keybindings": [
      {
        "command": "mybatisLogFormatter.formatCurrentDocument",
        "key": "shift+alt+f",
        "mac": "shift+option+f",
        "when": "editorTextFocus"
      },
      {
        "command": "mybatisLogFormatter.formatSelection",
        "key": "ctrl+k ctrl+m",
        "mac": "cmd+k cmd+m",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "mybatisLogFormatter.previewCurrentDocument",
        "key": "shift+alt+p",
        "mac": "shift+option+p",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit && tsc -p ./tsconfig.test.json --noEmit",
    "test": "vscode-test",
    "test:unit": "tsx node_modules/mocha/bin/mocha.js --ui tdd test/*.test.ts",
    "package": "vsce package",
    "prepublishOnly": "npm run check && npm run test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0",
    "mocha": "^10.2.0",
    "tsx": "^4.7.0"
  },
  "dependencies": {
    "sql-formatter": "^13.0.0"
  }
}
